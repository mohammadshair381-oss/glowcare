DEBUG=1
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (preferred)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=glowcare
DB_USER=glowcare
DB_PASSWORD=glowcare
DB_HOST=127.0.0.1
DB_PORT=5432

# Media
MEDIA_URL=/media/

# Email (password reset)
DEFAULT_FROM_EMAIL=no-reply@glowcare.local
# In development, console backend prints emails to stdout.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
